---
import type { GetStaticPaths } from 'astro'
import PostDetailPage from '~/components/pages/PostDetailPage.astro'
import { getPosts, slugOf } from '~/lib/content'

export const getStaticPaths = (async () => {
  const posts = await getPosts('zh')
  return posts.map((post) => ({
    params: { category: post.data.category.slug, slug: slugOf(post.id) },
    props: { post },
  }))
}) satisfies GetStaticPaths

const { post } = Astro.props
---

<PostDetailPage locale="zh" post={post} />
