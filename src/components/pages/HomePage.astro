---
// Hero-only home page; the self-introduction renders inside Hero, right
// under the slogan. RecentWriting (SecondScreen) and HomePageTimeLine
// were removed; their components remain under modules/home if ever needed.
import type { Locale } from '~/i18n/config'
import BaseLayout from '~/layouts/BaseLayout.astro'
import Hero from '~/components/modules/home/Hero.astro'

interface Props {
  locale: Locale
}

const { locale } = Astro.props
---

<BaseLayout locale={locale}>
  <Hero locale={locale} />
</BaseLayout>
