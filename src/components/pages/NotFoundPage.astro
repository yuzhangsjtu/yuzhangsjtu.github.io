---
// Ports components/common/404.tsx「撕下的便笺」— staged React transitions
// become CSS keyframes with matching delays/curves.
import type { Locale } from '~/i18n/config'
import { localizePath, useTranslations } from '~/i18n'
import BaseLayout from '~/layouts/BaseLayout.astro'

interface Props {
  locale: Locale
}

const { locale } = Astro.props
const t = useTranslations(locale, 'error')
---

<BaseLayout locale={locale} title="404">
  <section
    class="fill-content relative flex w-full flex-col items-center justify-center overflow-x-hidden overflow-y-visible px-4 py-10 sm:px-8 sm:py-14"
  >
    <div
      class="nf-wrap relative mx-auto max-w-[min(100%,380px)] px-6 pb-14 pt-4 sm:px-8 sm:pb-16 sm:pt-6"
    >
      <div
        class="nf-tape absolute top-1 left-1/2 z-10 h-6 w-16 rounded-sm bg-gradient-to-r from-accent/25 via-accent/40 to-accent/25 text-neutral-6 md:top-2 md:h-7 md:w-20"
        style="mask-image: linear-gradient(90deg, transparent 0%, black 10%, black 90%, transparent 100%);"
      >
        <div
          class="h-full w-full opacity-40"
          style="background-image: repeating-linear-gradient(45deg, transparent, transparent 2px, currentColor 2px, currentColor 3px);"
        >
        </div>
      </div>

      <div
        class="nf-note relative w-[280px] rounded-xl border border-neutral-9/10 bg-[#fefefb] p-6 dark:border-white/[0.08] dark:bg-neutral-2 md:w-[340px] md:p-8"
      >
        <div
          class="pointer-events-none absolute top-16 right-6 left-6 space-y-6 opacity-[0.08]"
        >
          {
            Array.from({ length: 8 }, () => (
              <div class="h-px w-full bg-neutral-6/40 dark:bg-neutral-5/30" />
            ))
          }
        </div>

        <div class="relative">
          <h1
            class="nf-rise text-neutral-10 mb-3 font-sans text-display-48 font-semibold tracking-tight md:text-display-48"
            style="--nf-delay: 600ms"
          >
            404
          </h1>

          <p
            class="nf-rise mb-6 font-serif text-copy-14 leading-relaxed text-neutral-7 italic md:text-copy-16 dark:text-neutral-5"
            style="--nf-delay: 680ms"
          >
            {t('404_torn_line1')}
            <br />
            {t('404_torn_line2')}
          </p>

          <div class="nf-divider my-6 h-px w-12 bg-accent/45"></div>

          <div class="nf-rise space-y-3" style="--nf-delay: 880ms">
            <p
              class="mb-4 text-caption-10 tracking-[3px] text-neutral-6 uppercase dark:text-neutral-5"
            >
              {t('404_torn_todo')}
            </p>

            <a
              class="group flex items-center gap-3"
              href={localizePath(locale, '/')}
            >
              <span
                class="flex h-4 w-4 items-center justify-center rounded border border-neutral-5 transition-all duration-200 group-hover:translate-y-px group-hover:border-accent group-hover:bg-accent/10 dark:border-neutral-4"
              >
                <svg
                  class="h-2.5 w-2.5 text-accent opacity-0 transition-opacity duration-200 group-hover:opacity-100"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  viewBox="0 0 24 24"
                >
                  <path
                    d="M5 13l4 4L19 7"
                    stroke-linecap="round"
                    stroke-linejoin="round"></path>
                </svg>
              </span>
              <span
                class="text-copy-13 text-neutral-8 transition-all duration-200 group-hover:translate-y-px group-hover:text-neutral-10"
              >
                {t('404_backHome')}
              </span>
            </a>
          </div>

          <p
            class="nf-rise mt-10 text-right font-serif text-label-12 text-neutral-7 italic dark:text-neutral-5"
            style="--nf-delay: 1000ms"
          >
            {t('404_torn_signature')}
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .nf-wrap {
    transform: rotate(3deg);
    animation: nf-settle 800ms cubic-bezier(0.22, 1, 0.36, 1) 150ms forwards;
  }
  @keyframes nf-settle {
    to {
      transform: rotate(-1.5deg);
    }
  }

  .nf-note {
    transform: translateY(40px);
    opacity: 0;
    box-shadow: 0 24px 72px rgba(15, 15, 15, 0.14);
    animation: nf-note-in 700ms cubic-bezier(0.22, 1, 0.36, 1) 150ms forwards;
  }
  @keyframes nf-note-in {
    to {
      transform: translateY(0);
      opacity: 1;
      box-shadow:
        0 4px 28px rgba(15, 15, 15, 0.07),
        0 18px 64px rgba(15, 15, 15, 0.1);
    }
  }

  .nf-tape {
    transform: translateX(-50%) translateY(-30px) rotate(-5deg);
    opacity: 0;
    animation: nf-tape-in 600ms cubic-bezier(0.22, 1, 0.36, 1) 400ms forwards;
  }
  @keyframes nf-tape-in {
    to {
      transform: translateX(-50%) translateY(0) rotate(2deg);
      opacity: 1;
    }
  }

  .nf-rise {
    transform: translateY(12px);
    opacity: 0;
    animation: nf-rise-in 500ms cubic-bezier(0.22, 1, 0.36, 1)
      var(--nf-delay, 600ms) forwards;
  }
  @keyframes nf-rise-in {
    to {
      transform: translateY(0);
      opacity: 1;
    }
  }

  .nf-divider {
    transform: scaleX(0);
    transform-origin: left;
    animation: nf-divider-in 600ms cubic-bezier(0.22, 1, 0.36, 1) 800ms
      forwards;
  }
  @keyframes nf-divider-in {
    to {
      transform: scaleX(1);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .nf-wrap,
    .nf-note,
    .nf-tape,
    .nf-rise,
    .nf-divider {
      animation-duration: 0ms;
      animation-delay: 0ms;
    }
  }
</style>
