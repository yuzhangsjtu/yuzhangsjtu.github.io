---
// Ports app/[locale]/notes/page.tsx + NoteListTimeline + NoteListItemPaper.
// Latest-note inline reader, topics, bookmark/cover come from frontmatter;
// pagination is simplified to a single timeline (content sets are static).
import type { Locale } from '~/i18n/config'
import { localizePath, useTranslations } from '~/i18n'
import { getNotes, notePath } from '~/lib/content'
import BaseLayout from '~/layouts/BaseLayout.astro'
import Paper from '~/components/layout/Paper.astro'

interface Props {
  locale: Locale
}

const { locale } = Astro.props
const t = useTranslations(locale, 'note')
const tCommon = useTranslations(locale, 'common')

const notes = await getNotes(locale)

interface YearGroup {
  year: number
  notes: typeof notes
}
const groups: YearGroup[] = []
for (const note of notes) {
  const year = note.data.date.getFullYear()
  const group = groups.find((g) => g.year === year)
  if (group) group.notes.push(note)
  else groups.push({ year, notes: [note] })
}

const dateLocale = locale === 'zh' ? 'zh-CN' : 'en'
const monthOf = (d: Date) =>
  new Intl.DateTimeFormat(dateLocale, { month: 'long' }).format(d)
const weekdayShort = (d: Date) =>
  new Intl.DateTimeFormat(dateLocale, { weekday: 'short' }).format(d)
const monthDayWeekday = (d: Date) =>
  new Intl.DateTimeFormat(dateLocale, {
    month: 'long',
    day: 'numeric',
    weekday: 'short',
  }).format(d)
---

<BaseLayout locale={locale} title={tCommon('nav_notes')}>
  <div class="mx-auto mt-24 min-w-0 max-w-5xl px-4">
    <div class="space-y-14">
      {
        groups.map((group) => (
          <section class="relative">
            <div class="mb-7 flex items-baseline gap-5 border-b border-[rgba(60,40,20,0.10)] pb-2.5 dark:border-white/[0.08]">
              <div>
                <div class="text-caption-10 uppercase tracking-[0.28em] text-[#b09a78] dark:text-[#8a7860]">
                  Anno
                </div>
                <div class="mt-0.5 text-display-36 font-medium leading-none tracking-tight text-neutral-9">
                  {group.year}
                </div>
              </div>
              <div class="flex-1 text-right text-caption-10 uppercase tracking-[0.18em] text-neutral-6">
                {group.notes.length} letter{group.notes.length === 1 ? '' : 's'}
              </div>
            </div>

            <div class="relative space-y-6">
              <div class="absolute bottom-0 left-[11px] top-1 w-px bg-[rgba(60,40,20,0.12)] dark:bg-white/[0.08] lg:hidden" />

              {group.notes.map((note) => {
                const date = note.data.date
                const metaParts: string[] = []
                if (note.data.weather) metaParts.push(note.data.weather)
                if (note.data.mood) metaParts.push(note.data.mood)
                return (
                  <div class="relative flex items-stretch gap-6 lg:gap-6">
                    <div class="hidden w-16 shrink-0 border-r border-[rgba(60,40,20,0.08)] pr-3.5 pt-1 text-right dark:border-white/[0.06] lg:block">
                      <div class="text-title-28 font-medium leading-none tracking-tight text-neutral-9">
                        {String(date.getDate()).padStart(2, '0')}
                      </div>
                      <div class="mt-1.5 text-caption-10 uppercase tracking-[0.18em] text-neutral-6">
                        {monthOf(date)}
                      </div>
                      <div class="mt-0.5 text-caption-10 uppercase tracking-[0.16em] text-[#b09a78] dark:text-[#8a7860]">
                        {weekdayShort(date)}
                      </div>
                    </div>

                    <div class="absolute left-[7px] top-2 size-[10px] shrink-0 rounded-full border-[1.5px] border-[rgba(60,40,20,0.25)] bg-[#faf6ee] dark:border-white/30 dark:bg-neutral-2 lg:hidden" />

                    <div class="min-w-0 flex-1 pl-8 lg:pl-0">
                      <div class="mb-1.5 text-caption-10 uppercase tracking-[0.16em] text-neutral-6 lg:hidden">
                        {monthDayWeekday(date)}
                      </div>
                      <!-- NoteListItemPaper -->
                      <a
                        class="group block"
                        href={localizePath(locale, notePath(note))}
                      >
                        <Paper class="!m-0 transition-transform duration-150 hover:-translate-y-0.5" contentClass="!p-0">
                          <div class="px-5 pb-4 pt-3.5">
                            {metaParts.length > 0 && (
                              <div class="mb-1.5 flex flex-wrap items-center gap-x-2 gap-y-1 text-caption-10 uppercase tracking-[0.16em] text-neutral-6">
                                {metaParts.map((part, i) => (
                                  <span class="flex items-center gap-2">
                                    {i > 0 && (
                                      <span
                                        aria-hidden
                                        class="size-[3px] rounded-full bg-neutral-6/60"
                                      />
                                    )}
                                    {part}
                                  </span>
                                ))}
                              </div>
                            )}

                            <h3 class="m-0 text-copy-16 font-medium leading-snug tracking-tight text-neutral-9 transition-colors group-hover:text-accent">
                              {note.data.title}
                            </h3>

                            {note.data.summary && (
                              <p class="mt-1 truncate text-copy-13 leading-relaxed text-neutral-7">
                                {note.data.summary}
                              </p>
                            )}

                            <div class="mt-2.5 flex items-baseline justify-between gap-4 border-t border-[rgba(60,40,20,0.06)] pt-2 dark:border-white/[0.05]">
                              <span class="text-caption-10 uppercase tracking-[0.22em] text-[#b09a78] dark:text-[#8a7860]">
                                Letter №<span class="tabular-nums">{note.data.nid}</span>
                              </span>
                              <span class="text-label-12 italic tracking-[0.03em] text-[#8c6239] transition-opacity group-hover:opacity-70 dark:text-[#d4a574]">
                                {t('read_full_note')} →
                              </span>
                            </div>
                          </div>
                        </Paper>
                      </a>
                    </div>
                  </div>
                )
              })}
            </div>
          </section>
        ))
      }
    </div>
  </div>
</BaseLayout>
