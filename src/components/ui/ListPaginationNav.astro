---
// Ported from ui/pagination/ListPaginationNav.tsx
interface Props {
  ariaLabel?: string
  hasNext: boolean
  hasPrev: boolean
  info?: string
  nextHref?: string
  nextLabel: string
  prevHref?: string
  prevLabel: string
}

const {
  hasPrev,
  hasNext,
  prevHref,
  nextHref,
  prevLabel,
  nextLabel,
  info,
  ariaLabel = 'Pagination',
} = Astro.props

const baseClass =
  'inline-flex items-center gap-1.5 text-label-12 uppercase tracking-[2.5px]'
const linkClass = `${baseClass} text-neutral-7 transition-colors hover:text-accent focus-visible:text-accent focus-visible:outline-none`
const disabledClass = `${baseClass} text-neutral-4 cursor-default`
const iconClass = 'text-copy-13 shrink-0'
---

<nav
  aria-label={ariaLabel}
  class:list={[
    'mt-20 border-t border-neutral-3/60 pt-5',
    'grid grid-cols-[1fr_auto_1fr] items-center gap-3',
  ]}
>
  {
    hasPrev && prevHref ? (
      <a aria-label={prevLabel} class={linkClass} href={prevHref}>
        <i aria-hidden class={`i-mingcute-arrow-left-line ${iconClass}`} />
        <span>{prevLabel}</span>
      </a>
    ) : (
      <span aria-disabled class={disabledClass}>
        <i aria-hidden class={`i-mingcute-arrow-left-line ${iconClass}`} />
        <span>{prevLabel}</span>
      </span>
    )
  }

  <span aria-hidden class="text-neutral-4">·</span>

  {
    hasNext && nextHref ? (
      <a
        aria-label={nextLabel}
        class={`${linkClass} justify-self-end`}
        href={nextHref}
      >
        <span>{nextLabel}</span>
        <i aria-hidden class={`i-mingcute-arrow-right-line ${iconClass}`} />
      </a>
    ) : (
      <span aria-disabled class={`${disabledClass} justify-self-end`}>
        <span>{nextLabel}</span>
        <i aria-hidden class={`i-mingcute-arrow-right-line ${iconClass}`} />
      </span>
    )
  }

  {
    info && (
      <span class="col-span-full mt-2 text-center text-caption-10 uppercase tracking-[3px] text-neutral-5 tabular-nums">
        {info}
      </span>
    )
  }
</nav>
