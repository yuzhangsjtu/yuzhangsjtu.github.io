---
// Ported from modules/post/PostFeaturedCard.tsx (pinned post card).
import type { Locale } from '~/i18n/config'
import { localizePath, useTranslations } from '~/i18n'
import type { PostEntry } from '~/lib/content'
import { postPath } from '~/lib/content'

interface Props {
  locale: Locale
  post: PostEntry
}

const { locale, post } = Astro.props
const t = useTranslations(locale, 'common')
const data = post.data

const postLink = localizePath(locale, postPath(post))
const summary =
  data.summary || (post.body ? post.body.replaceAll(/[#*`>\[\]]/g, '').trim().slice(0, 150) : '')
---

<a
  href={postLink}
  class:list={[
    'mt-5 block rounded-md p-5 lg:-mx-4',
    'bg-white/50 border border-black/5',
    'dark:bg-white/5 dark:border-white/5',
    'transition-all duration-250',
    'hover:shadow-[0_2px_16px_rgba(0,0,0,0.05)] hover:-translate-y-px',
  ]}
>
  <div class="flex gap-4">
    <div class="min-w-0 flex-1">
      <div class="mb-2 text-label-12 tracking-[1px] text-accent">
        {t('pinned_label')}
      </div>
      <h2
        class="flex items-baseline gap-2 text-copy-16 font-medium text-neutral-9"
      >
        <span>{data.title}</span>
      </h2>
      {
        summary && (
          <p class="mt-2 line-clamp-2 text-copy-13 leading-[1.7] text-neutral-6">
            {summary}
          </p>
        )
      }
      <div class="mt-3 flex items-center justify-between">
        <div class="flex items-center gap-2 text-label-12">
          <span class="text-neutral-5">
            <time data-relative-time datetime={data.date.toISOString()}></time>
          </span>
          {data.modified && <span class="text-neutral-4">{t('edited')}</span>}
          {
            data.category && (
              <>
                <span class="text-neutral-4">·</span>
                <span class="yohaku-link--underline text-accent">
                  {data.category.name}
                </span>
                {data.tags?.length ? (
                  <>
                    {' / '}
                    {data.tags.map((tag, index) => (
                      <>
                        <span class="yohaku-link--underline text-accent">
                          {tag}
                        </span>
                        {index < data.tags.length - 1 && ', '}
                      </>
                    ))}
                  </>
                ) : null}
              </>
            )
          }
        </div>
      </div>
    </div>
  </div>
</a>
