---
// Ported from (home)/components/SectionHeading.tsx
import type { Locale } from '~/i18n/config'

const EYEBROW = {
  recentWriting: 'Recent Writing',
  musings: 'Musings',
  letters: 'Letters',
} as const

interface Props {
  eyebrow: keyof typeof EYEBROW
  locale: Locale
}

const { eyebrow, locale } = Astro.props
const showEyebrow = locale !== 'en'
---

<div class="mb-5 lg:mb-6">
  {
    showEyebrow && (
      <div class="text-caption-10 uppercase tracking-[1.5px] text-neutral-5">
        {EYEBROW[eyebrow]}
      </div>
    )
  }
  <div
    class:list={[
      showEyebrow && 'mt-1.5',
      'font-serif text-title-20 tracking-[2px] text-neutral-7 lg:text-title-24',
    ]}
  >
    <slot />
  </div>
</div>
