---
// Ported from components/layout/footer/{Footer,FooterInfo,config}.tsx.
// Removed: GatewayInfo (socket online count), SubscribeTextButton, the
// PoweredBy hover popover. Markup/classes otherwise verbatim.
import type { Locale } from '~/i18n/config'
import { localizePath, useTranslations } from '~/i18n'
import { siteConfig } from '~/site.config'
import LocaleSwitcher from './LocaleSwitcher.astro'
import ThemeSwitcher from './ThemeSwitcher.astro'

interface Props {
  locale: Locale
  pathname: string
}

const { locale, pathname } = Astro.props
const t = useTranslations(locale, 'common')

// getDefaultLinkSections (footer/config.ts) — backend-only targets removed.
const linkSections = [
  {
    name: t('footer_section_about'),
    links: [
      { name: t('footer_about_site'), href: '/about-site' },
      { name: t('footer_about_me'), href: '/about-me' },
      {
        name: t('footer_about_project'),
        href: 'https://github.com/Innei/Yohaku',
        external: true,
      },
    ],
  },
  {
    name: t('footer_section_more'),
    links: [
      { name: t('nav_timeline'), href: '/timeline' },
      { name: t('nav_projects'), href: '/projects' },
      { name: t('nav_friends'), href: '/friends' },
    ],
  },
  {
    name: t('footer_section_contact'),
    links: [
      {
        name: t('footer_send_email'),
        href: `mailto:${siteConfig.user.socialIds.mail ?? ''}`,
        external: true,
      },
      {
        name: 'GitHub',
        href: `https://github.com/${siteConfig.user.socialIds.github ?? ''}`,
        external: true,
      },
    ],
  },
]

const currentYear = new Date().getFullYear().toString()
const { date: dateRaw, icp } = siteConfig.footer.otherInfo
const copyrightDate = (dateRaw || currentYear).replace('{{now}}', currentYear)
const ownerName = siteConfig.user.name

const allLinks = linkSections.flatMap((s) => s.links)
const resolveHref = (link: { href: string; external?: boolean }) =>
  link.external ? link.href : localizePath(locale, link.href)
---

<!-- Gradient fade boundary -->
<div
  data-hide-print
  class="relative z-[1] mt-32 -mb-px h-9 md:h-16"
  style="background: linear-gradient(to bottom, transparent, color-mix(in oklab, var(--color-accent) 5%, var(--color-root-bg, #fff)));"
>
</div>

<footer
  data-hide-print
  class="relative z-[1] pb-12 pt-0"
  style="background: color-mix(in oklab, var(--color-accent) 5%, var(--color-root-bg, #fff));"
>
  <div class="px-4 sm:px-8">
    <div class="mx-auto min-w-0 max-w-7xl lg:px-8">
      <!-- Desktop: asymmetric split -->
      <div class="hidden min-w-0 md:flex md:gap-20">
        <!-- Left: brand column -->
        <div class="w-80 max-w-[min(100%,24rem)] shrink-0">
          <div
            class="text-title-20 font-semibold tracking-wide text-neutral-9"
          >
            <a href={localizePath(locale, '/')}>{ownerName}</a>
          </div>
          <div
            class="mt-2 text-copy-13 leading-relaxed italic text-neutral-7"
          >
            {t('footer_motto')}
          </div>

          <div class="mt-7 text-copy-13 leading-normal text-neutral-6">
            <div>
              © {copyrightDate}{' '}
              <span>
                Powered by{' '}
                <a
                  class="underline decoration-black/15 underline-offset-2 dark:decoration-white/10"
                  href="https://github.com/mx-space"
                  rel="noreferrer"
                  target="_blank">Mix Space</a
                >
                <span class="mx-0.5">&</span>
                <a
                  class="underline decoration-black/15 underline-offset-2 dark:decoration-white/10"
                  href="https://github.com/Innei/Yohaku"
                  rel="noreferrer"
                  target="_blank">余白 / Yohaku</a
                >.
              </span>
            </div>
          </div>
        </div>

        <!-- Right: link columns -->
        <div class="flex min-w-0 flex-1 justify-end gap-30 pt-0.5">
          {
            linkSections.map((section) => (
              <div>
                <div class="mb-3.5 text-copy-13 font-medium uppercase tracking-[3px] text-neutral-6">
                  {section.name}
                </div>
                <div class="text-copy-13 leading-[2.6]">
                  {section.links.map((link) => (
                    <a
                      class="block text-neutral-8/90 hover:underline hover:decoration-current/30 hover:underline-offset-2"
                      href={resolveHref(link)}
                      rel={link.external ? 'noreferrer' : undefined}
                      target={link.external ? '_blank' : undefined}
                    >
                      {link.name}
                      {link.external && (
                        <span class="ml-0.5 text-neutral-6"> ↗</span>
                      )}
                    </a>
                  ))}
                </div>
              </div>
            ))
          }
        </div>
      </div>

      <!-- Mobile: flat inline flow -->
      <div class="md:hidden">
        <div class="mb-6">
          <div class="mb-1.5 text-copy-16 font-semibold text-neutral-9">
            <a href={localizePath(locale, '/')}>{ownerName}</a>
          </div>
          <div class="text-copy-13 leading-relaxed italic text-neutral-7">
            {t('footer_motto')}
          </div>
        </div>

        <div class="mb-6">
          <div
            class="mb-2.5 text-copy-13 font-medium uppercase tracking-[3px] text-neutral-6"
          >
            {t('footer_links_label')}
          </div>
          <div class="text-copy-13 leading-[2.4] text-neutral-8/90">
            {
              allLinks.map((link, i) => (
                <span>
                  <a
                    class="hover:underline hover:decoration-current/30 hover:underline-offset-2"
                    href={resolveHref(link)}
                    rel={link.external ? 'noreferrer' : undefined}
                    target={link.external ? '_blank' : undefined}
                  >
                    {link.name}
                  </a>
                  {i < allLinks.length - 1 && (
                    <span aria-hidden class="mx-1.5 select-none text-neutral-5">
                      ·
                    </span>
                  )}
                </span>
              ))
            }
          </div>
        </div>

        <div class="border-t border-black/4 pt-4 dark:border-white/4">
          <div class="text-copy-13 leading-relaxed text-neutral-6">
            <div>
              © {copyrightDate}{' '}
              <span>
                Powered by{' '}
                <a
                  class="underline decoration-black/15 underline-offset-2 dark:decoration-white/10"
                  href="https://github.com/mx-space"
                  rel="noreferrer"
                  target="_blank">Mix Space</a
                >
                <span class="mx-0.5">&</span>
                <a
                  class="underline decoration-black/15 underline-offset-2 dark:decoration-white/10"
                  href="https://github.com/Innei/Yohaku"
                  rel="noreferrer"
                  target="_blank">余白 / Yohaku</a
                >.
              </span>
            </div>
            {
              icp && (
                <div class="mt-0.5">
                  <a href={icp.link} rel="noreferrer" target="_blank">
                    {icp.text}
                  </a>
                </div>
              )
            }
          </div>
          <div class="mt-3.5 space-y-3 text-copy-13 text-neutral-6">
            <div>
              <a href="/feed.xml" rel="noreferrer" target="_blank"
                >{t('rss_subscribe')}</a
              >
              <span aria-hidden class="mx-1.5 select-none text-neutral-5"
                >·</span
              >
              <a href="/sitemap-index.xml" rel="noreferrer" target="_blank"
                >{t('sitemap')}</a
              >
            </div>
            <div class="flex items-center gap-3">
              <ThemeSwitcher locale={locale} />
              <span aria-hidden class="select-none text-neutral-4">|</span>
              <LocaleSwitcher locale={locale} pathname={pathname} />
            </div>
          </div>
        </div>
      </div>

      <!-- Desktop bottom bar -->
      <div
        class="mt-8 hidden border-t border-black/4 pt-4 dark:border-white/4 md:flex md:items-center md:justify-between"
      >
        <span class="flex items-center gap-4 text-copy-13 text-neutral-6">
          <span>
            <a href="/feed.xml" rel="noreferrer" target="_blank"
              >{t('rss_subscribe')}</a
            >
            <span aria-hidden class="mx-1.5 select-none text-neutral-5">·</span>
            <a href="/sitemap-index.xml" rel="noreferrer" target="_blank"
              >{t('sitemap')}</a
            >
          </span>
          <span aria-hidden class="select-none text-neutral-4">|</span>
          <ThemeSwitcher locale={locale} />
          <span aria-hidden class="select-none text-neutral-4">|</span>
          <LocaleSwitcher locale={locale} pathname={pathname} />
        </span>
        {
          icp && (
            <span class="text-copy-13 text-neutral-6">
              <a href={icp.link} rel="noreferrer" target="_blank">
                {icp.text}
              </a>
            </span>
          )
        }
      </div>
    </div>
  </div>
</footer>
