---
// Ported from components/layout/header/{Header,internal/*}.tsx.
// Backend-driven parts (UserAuth, Activity, OwnerStatus, live state,
// dropdown mega-menus) are removed. The desktop nav is restyled away from
// the Shiro segmented-control look — see the nav block below.
import type { Locale } from '~/i18n/config'
import { localizePath, unlocalizePath, useTranslations } from '~/i18n'
import { siteConfig, localizedSite } from '~/site.config'

interface Props {
  locale: Locale
  pathname: string
}

const { locale, pathname } = Astro.props
const t = useTranslations(locale, 'common')

// headerMenuConfig (header/config.ts), narrowed to pages that exist without
// the mx-space backend. Friends is promoted from the "More" submenu.
const headerMenuConfig = [
  {
    title: t('nav_home'),
    path: '/',
    icon: 'i-mingcute-home-4-line',
  },
  {
    title: t('nav_posts'),
    path: '/posts',
    icon: 'i-mingcute-news-line',
  },
  {
    title: t('nav_notes'),
    path: '/notes',
    icon: 'i-mingcute-quill-pen-line',
  },
  {
    title: t('nav_timeline'),
    path: '/timeline',
    icon: 'i-mingcute-history-line',
  },
  {
    title: t('nav_projects'),
    path: '/projects',
    icon: 'i-mingcute-flask-line',
  },
  {
    title: t('nav_friends'),
    path: '/friends',
    icon: 'i-mingcute-group-line',
  },
]

const currentPath = unlocalizePath(pathname).replace(/\/$/, '') || '/'
const isActive = (path: string) =>
  currentPath === path || (path !== '/' && currentPath.startsWith(`${path}/`))

const siteTitle = localizedSite[locale].seo.title
const { avatar } = siteConfig.user
---

<!-- Mobile header (MobileHeader.tsx) -->
<div
  id="mobile-header"
  role="banner"
  data-open="false"
  class="fixed inset-x-0 top-0 z-[9] px-3.5 pt-2.5 lg:hidden transition-[opacity,transform] duration-[350ms] ease-[cubic-bezier(0.22,1,0.36,1)]"
>
  <div
    class:list={[
      'rounded-[20px]',
      'bg-[#fefefb] dark:bg-neutral-2',
      'border border-black/5 dark:border-white/[0.04]',
      'shadow-[0_1px_2px_rgba(0,0,0,0.04),0_4px_14px_rgba(0,0,0,0.06)]',
      'dark:shadow-[0_1px_2px_rgba(0,0,0,0.15),0_4px_12px_rgba(0,0,0,0.1)]',
    ]}
  >
    <button
      id="mobile-header-toggle"
      aria-expanded="false"
      class="flex w-full items-center justify-between px-4 py-2.5"
    >
      <span
        class="font-serif text-copy-15 tracking-[0.05em] text-neutral-8 dark:text-neutral-8"
        >{siteTitle}</span
      >
      <div class="flex items-center gap-2">
        <span class="flex size-8 items-center justify-center text-neutral-5">
          <i class="i-mingcute-menu-line text-icon-md"></i>
        </span>
      </div>
    </button>

    <div
      id="mobile-header-panel"
      class="overflow-hidden transition-[height,opacity] duration-[250ms] ease-[cubic-bezier(0.22,1,0.36,1)]"
      style="height: 0px; opacity: 0;"
    >
      <div class="mx-4 h-px bg-neutral-9/[0.05] dark:bg-white/[0.05]"></div>
      <nav class="px-3 py-2">
        {
          headerMenuConfig.map((section) => (
            <a
              href={localizePath(locale, section.path)}
              class:list={[
                'flex items-center gap-3 rounded-xl px-3 py-2.5 text-copy-14',
                isActive(section.path)
                  ? 'text-neutral-9 bg-black/[0.03] dark:bg-white/[0.06]'
                  : 'text-neutral-7',
              ]}
            >
              <i
                class:list={[
                  section.icon,
                  'text-icon-md',
                  isActive(section.path) ? 'text-accent' : 'text-neutral-6',
                ]}
              />
              <span>{section.title}</span>
            </a>
          ))
        }
      </nav>
    </div>
  </div>
</div>

<!-- Desktop fixed bar: logo / spacer / (auth removed) (Header.tsx) -->
<div
  data-hide-print
  class="yohaku-page-right-inset fixed top-0 z-[9] hidden h-[4.5rem] lg:inset-x-0 lg:block"
>
  <div
    class="header--grid relative mx-auto grid h-full min-h-0 max-w-7xl grid-cols-[4.5rem_1fr_4.5rem] px-8"
  >
    <div id="header-logo-area" class="header--grid__logo relative">
      <div class="relative flex size-full items-center justify-center">
        <!-- SiteOwnerAvatar.tsx (live/status removed) -->
        <a
          href={localizePath(locale, '/')}
          class="relative z-[9] size-[40px] select-none"
          aria-label={t('aria_site_owner_avatar')}
        >
          <div class="mask mask-squircle overflow-hidden">
            <img
              alt={t('aria_site_owner_avatar')}
              class="ring-2 ring-neutral-3"
              height="40"
              width="40"
              src={avatar}
            />
          </div>
        </a>
      </div>
    </div>

    <div></div>

    <div class="flex size-full items-center"></div>
  </div>
</div>

<!-- Floating centered nav. Diverges from the Shiro port: the segmented-control
     pill (glass box, item dividers, raised active card + icon) is replaced by
     bare letter-spaced text on the paper; the active page carries the site's
     accent underline (same language as .yohaku-link--underline) and a soft
     paper pill only materializes once scrolled (.nav-solid). -->
<div
  id="header-nav-portal"
  class="yohaku-page-right-inset pointer-events-none fixed inset-x-0 top-4 z-10 mr-[var(--removed-body-scroll-bar-size)] hidden justify-center lg:flex transition-[opacity,transform] duration-200"
>
  <nav
    id="header-nav-root"
    class:list={[
      'relative rounded-full',
      'border border-transparent',
      'pointer-events-auto',
      'transition-[background-color,border-color,box-shadow,backdrop-filter] duration-300',
    ]}
  >
    <ul class="flex list-none items-center gap-0.5 px-3 text-copy-14">
      {
        headerMenuConfig.map((section) => (
          <li class="contents">
            <a
              href={localizePath(locale, section.path)}
              aria-current={isActive(section.path) ? 'page' : undefined}
              class:list={[
                'nav-item relative block whitespace-nowrap px-2.5 py-1.5 tracking-[0.05em]',
                'transition-colors duration-200',
                isActive(section.path)
                  ? 'nav-active font-medium text-neutral-9'
                  : 'text-neutral-6 hover:text-neutral-9',
              ]}
            >
              <span class="nav-label">{section.title}</span>
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</div>

<style>
  /* Active/hover marker: the site's accent underline (mirrors
     .yohaku-link--underline) — 1px line grows from the left on hover,
     held full-width on the active page. */
  .nav-label {
    background-image: linear-gradient(var(--color-accent), var(--color-accent));
    background-size: 0% 1px;
    background-repeat: no-repeat;
    background-position: 0 100%;
    transition: background-size 500ms ease;
  }
  .nav-item:hover .nav-label {
    background-size: 100% 1px;
    transition: background-size 250ms ease;
  }
  .nav-active .nav-label {
    background-size: 100% 1px;
  }

  /* Scrolled state: warm paper pill fades in under the text. */
  #header-nav-root.nav-solid {
    background-color: rgb(254 254 251 / 0.88);
    border-color: rgb(0 0 0 / 0.05);
    backdrop-filter: blur(12px);
    box-shadow:
      0 1px 2px rgba(0, 0, 0, 0.04),
      0 6px 20px -8px rgba(0, 0, 0, 0.1);
  }
  :global([data-theme='dark']) #header-nav-root.nav-solid {
    background-color: rgb(23 23 23 / 0.85);
    border-color: rgb(255 255 255 / 0.06);
    box-shadow:
      0 1px 2px rgba(0, 0, 0, 0.2),
      0 6px 20px -8px rgba(0, 0, 0, 0.35);
  }
</style>
